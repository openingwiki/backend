{
  "openapi": "3.0.3",
  "info": {
    "title": "Opening.wiki - OpenAPI 3.0",
    "description": "The first of API for opening.wiki. Contains requests to work with openings and anime.",
    "contact": {
      "email": "jakefish.work@gmail.com"
    },
    "license": {
      "name": "Apache 2.0",
      "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "version": "0.0.1"
  },
  "paths": {
    "/openings": {
      "get": {
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Count of openings needed",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Offset of the openings in request",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Opening"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/openings/{opening_id}": {
      "get": {
        "parameters": [
          {
            "name": "opening_id",
            "in": "path",
            "required": true,
            "description": "Opening id to get",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Opening"
                }
              }
            },
            "description": "success"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Anime": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Opening": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "anime": {
            "type": "object"
          }
        }
      }
    }
  }
}